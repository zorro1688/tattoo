{
  "name": "tattoo-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:static": "node server.mjs",
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "test:billing": "node tests/billing-core.test.mjs",
    "test:generate": "node tests/generation-core.test.mjs && node tests/generation-quality-api.test.mjs",
    "test:quota": "node tests/quota-store.test.mjs",
    "test:quality": "node tests/quality-evaluation-dataset.test.mjs && node tests/quality-evaluation-core.test.mjs && node tests/quality-evaluation-cli.test.mjs && node tests/quality-evaluation-setup.test.mjs",
    "eval:quality": "node scripts/evaluate-generation-quality.mjs",
    "test:supabase": "node tests/supabase-schema.test.mjs && node tests/supabase-store.test.mjs",
    "check:billing": "node scripts/check-billing-setup.mjs",
    "migrate:storage-paths": "node scripts/migrate-storage-paths.mjs",
    "test:regression": "node scripts/regression-check.mjs",
    "check:prod": "node scripts/check-production-setup.mjs",
    "verify:supabase": "node scripts/verify-supabase-cloud.mjs",
    "check:full-flow": "node scripts/full-flow-check.mjs"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "next": "^15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "eslint": "9.17.0",
    "eslint-config-next": "^15.5.19",
    "supabase": "^2.106.0",
    "typescript": "5.7.2"
  }
}
